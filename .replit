modules = ["nodejs-20", "web"]
run = "undo website"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "undo website"]

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 36014909

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[ports]]
localPort = 3000
externalPort = 80
